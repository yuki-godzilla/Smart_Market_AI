APP_NAME=smai-ai-gateway
APP_ENV=local
SMAI_OLLAMA_BASE_URL=http://localhost:11434

# Notebook development recommended
SMAI_LLM_PROFILE=notebook_dev
SMAI_OLLAMA_MODEL=llama3.2:3b

# Legacy aliases are still accepted by the Gateway.
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_MODEL=llama3.2:3b
REQUEST_TIMEOUT_SECONDS=30
ENABLE_DEBUG_LOG=false
